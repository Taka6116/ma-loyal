# 認証（ログイン画面で使用）
# 本番・Vercel では Vercel の「Environment Variables」で設定してください。
AUTH_EMAIL=cellmuller_analytics@cellmuller.com
AUTH_PASSWORD=20220601
AUTH_SECRET=

# AUTH_SECRET は Cookie 署名用に 16 文字以上のランダム文字列を設定してください。
# 例: openssl rand -base64 24

# 追加ログイン（最大10件まで AUTH_EMAIL / AUTH_EMAIL_2 … _10）
# AUTH_EMAIL_2=
# パスワードは次のどちらか一方だけを設定（両方ある場合は B64 が優先される）
# - 平文: AUTH_PASSWORD_2=記号入りパスワードも可
# - Base64: AUTH_PASSWORD_B64_2=　← 中身は「パスワード文字列」を UTF-8 で Base64 エンコードした値。
#   平文パスワードをそのまま B64 変数名に入れないこと（デコード結果が別文字列になりログイン失敗する）
#   生成例（PowerShell）: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes('your-password'))
#   生成例（mac/Linux）: printf %s 'your-password' | base64

# S3（バケット名は S3_BUCKET_NAME など既存の変数で指定）
# 一次執筆が参照する資料フォルダ（キー先頭）。.md / .csv / .txt のみ読み込み。
# S3_DRAFT_MATERIALS_PREFIX=materials_for_articles/
